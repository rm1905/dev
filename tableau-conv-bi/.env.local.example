# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — secrets never get committed or shipped to the browser.

# --- Claude API ---
# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Model to use. Opus 4.8 is the most capable; switch to claude-sonnet-4-6 for lower cost.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Tableau MCP server ---
# The public HTTPS URL of your Tableau MCP server's streamable-HTTP (or SSE) endpoint.
# Examples (your path may differ depending on how you exposed it):
#   https://tableau-mcp.example.com/mcp
#   https://tableau-mcp.example.com/sse
TABLEAU_MCP_URL=https://your-mcp-host.example.com/mcp

# Optional. If your MCP endpoint requires a bearer token / API key, put it here.
# Leave blank/unset if the endpoint is open (network-protected only).
TABLEAU_MCP_TOKEN=

# A human-friendly name Claude uses to reference this MCP server. No spaces.
TABLEAU_MCP_NAME=tableau
